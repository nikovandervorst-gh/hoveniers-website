---
import Layout from '../layouts/Layout.astro';
import { bedrijf, diensten, portfolio } from '../data/content.js';
---

<Layout title={bedrijf.naam} bedrijfsnaam={bedrijf.naam}>

  <!-- Hero -->
  <section class="bg-green-700 text-white py-24 px-6 text-center">
    <h1 class="text-5xl font-bold mb-4">{bedrijf.naam}</h1>
    <p class="text-xl text-green-100">{bedrijf.tagline}</p>
    <a href="#contact" class="mt-8 inline-block bg-white text-green-700 font-semibold px-6 py-3 rounded-full hover:bg-green-100 transition">
      Neem contact op
    </a>
  </section>

	<!-- Over ons -->
	<section id="over-ons" class="py-20 px-6 max-w-3xl mx-auto text-center">
  	<h2 class="text-3xl font-bold text-green-700 mb-6">Over ons</h2>
  	<p class="text-gray-600 text-lg leading-relaxed">{bedrijf.beschrijving}</p>
	</section>

	<!-- Diensten -->
	<section id="diensten" class="py-20 px-6 bg-green-50">
  	<div class="max-w-5xl mx-auto">
    	<h2 class="text-3xl font-bold text-green-700 text-center mb-12">Onze diensten</h2>
    	<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      	{diensten.map((dienst) => (
        	<div class="bg-white rounded-2xl p-6 shadow-sm">
          	<h3 class="text-xl font-semibold text-green-700 mb-2">{dienst.titel}</h3>
          	<p class="text-gray-600">{dienst.omschrijving}</p>
        	</div>
      	))}
    	</div>
  	</div>
	</section>

	<!-- Portfolio -->
	<section id="portfolio" class="py-20 px-6">
  	<div class="max-w-5xl mx-auto">
    	<h2 class="text-3xl font-bold text-green-700 text-center mb-12">Ons werk</h2>
    	<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      	{portfolio.map((item) => (
        	<div class="rounded-2xl overflow-hidden shadow-sm">
          	<img src={item.afbeelding} alt={item.titel} class="w-full h-56 object-cover" />
          	<div class="bg-white px-4 py-3">
            	<p class="text-gray-700 font-medium">{item.titel}</p>
          	</div>
        	</div>
      	))}
    	</div>
  	</div>
	</section>

	<!-- Contact -->
	<section id="contact" class="py-20 px-6 bg-green-50">
  	<div class="max-w-xl mx-auto text-center">
    	<h2 class="text-3xl font-bold text-green-700 mb-4">Contact</h2>
    	<p class="text-gray-600 mb-8">Heeft u een vraag of wilt u een vrijblijvende offerte? Neem gerust contact op.	</p>

    	<form name="contact" method="POST" data-netlify="true" class="text-left space-y-4">
      	<input type="hidden" name="form-name" value="contact" />

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">Naam</label>
        	<input type="text" name="naam" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      	</div>

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">E-mailadres</label>
        	<input type="email" name="email" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      	</div>

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">Bericht</label>
        	<textarea name="bericht" rows="4" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400"></textarea>
      	</div>

      	<button type="submit"
        	class="w-full bg-green-700 text-white font-semibold py-3 rounded-xl hover:bg-green-800 transition">
        	Verstuur bericht
      	</button>
    	</form>

    	<div class="mt-10 text-gray-600 space-y-1">
      	<p>📞 {bedrijf.telefoon}</p>
      	<p>✉️ {bedrijf.email}</p>
    	</div>
  	</div>
	</section>

</Layout>