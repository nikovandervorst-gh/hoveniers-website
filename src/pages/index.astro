---
import Layout from '../layouts/Layout.astro';
import { bedrijf, diensten, portfolio } from '../data/content.js';
---

<Layout title={bedrijf.naam} bedrijfsnaam={bedrijf.naam}>

  	<!-- Hero -->
	<section class="relative text-white py-40 px-6 overflow-hidden" style="background: linear-gradient(135deg, #1a4a2e 0%, #2d7a4f 60%, #3a9a63 100%);">
		<div class="relative z-10 max-w-5xl mx-auto flex flex-col sm:flex-row items-center gap-12">

			<!-- Tekst links foto rechts -->

			<div class="flex-1 text-center sm:text-left">
				<p class="text-green-300 uppercase tracking-widest text-sm font-medium mb-4">Hoveniersbedrijf</p>
				<h1 class="text-6xl font-bold mb-6 leading-tight">{bedrijf.naam}</h1>
				<p class="text-xl text-green-100 mb-10 leading-relaxed">{bedrijf.tagline}</p>
				<a href="#contact" class="inline-block bg-white text-green-800 font-semibold px-8 py-4 rounded-full hover:bg-green-50 transition shadow-lg">
					Vraag een offerte aan →
				</a>
			</div>

			<div class="flex-shrink-0">
				<img
					src="/fotos/tomasz-removebg-preview.png"
					alt="Tomasz van Rees-Hoveniers"
					class="h-80 object-contain drop-shadow-2xl"
				/>
			</div>

		</div>
	</section>

	<!-- Over ons -->
	<section id="over-ons" class="py-20 px-6 max-w-3xl mx-auto text-center">
  	<h2 class="text-3xl font-bold text-green-700 mb-6">Over ons</h2>
  	<p class="text-gray-600 text-lg leading-relaxed">{bedrijf.beschrijving}</p>
	</section>

	<!-- Diensten -->
	<section id="diensten" class="py-24 px-6">
		<div class="max-w-5xl mx-auto">
	  		<p class="text-green-700 uppercase tracking-widest text-sm font-medium text-center mb-3">Wat wij doen</p>
	  		<h2 class="text-4xl font-bold text-center mb-16" style="color: #1a4a2e;">Onze diensten</h2>
	  		<div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
				{diensten.map((dienst) => (
		  		<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition">
					<div class="w-10 h-1 rounded mb-6" style="background-color: #2d7a4f;"></div>
					<h3 class="text-xl font-bold mb-3" style="color: #1a4a2e;">{dienst.titel}</h3>
					<p class="text-gray-500 leading-relaxed">{dienst.omschrijving}</p>
		  		</div>
				))}
	  		</div>
		</div>
  	</section>

	<!-- Portfolio -->
	<section id="portfolio" class="py-20 px-6">
  	<div class="max-w-5xl mx-auto">
    	<h2 class="text-3xl font-bold text-green-700 text-center mb-12">Ons werk</h2>
    	<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      	{portfolio.map((item) => (
        	<div class="rounded-2xl overflow-hidden shadow-sm">
          	<img src={item.afbeelding} alt={item.titel} class="w-full h-56 object-cover" />
          	<div class="bg-white px-4 py-3">
            	<p class="text-gray-700 font-medium">{item.titel}</p>
          	</div>
        	</div>
      	))}
    	</div>
  	</div>
	</section>

	<!-- Contact -->
	<section id="contact" class="py-20 px-6 bg-green-50">
  	<div class="max-w-xl mx-auto text-center">
    	<h2 class="text-3xl font-bold text-green-700 mb-4">Contact</h2>
    	<p class="text-gray-600 mb-8">Heeft u een vraag of wilt u een vrijblijvende offerte? Neem gerust contact op.	</p>

    	<form name="contact" method="POST" data-netlify="true" class="text-left space-y-4">
      	<input type="hidden" name="form-name" value="contact" />

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">Naam</label>
        	<input type="text" name="naam" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      	</div>

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">E-mailadres</label>
        	<input type="email" name="email" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      	</div>

      	<div>
        	<label class="block text-gray-700 font-medium mb-1">Bericht</label>
        	<textarea name="bericht" rows="4" required
          	class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400"></textarea>
      	</div>

      	<button type="submit"
        	class="w-full bg-green-700 text-white font-semibold py-3 rounded-xl hover:bg-green-800 transition">
        	Verstuur bericht
      	</button>
    	</form>

    	<div class="mt-10 text-gray-600 space-y-1">
      	<p>📞 {bedrijf.telefoon}</p>
      	<p>✉️ {bedrijf.email}</p>
    	</div>
  	</div>
	</section>

</Layout>